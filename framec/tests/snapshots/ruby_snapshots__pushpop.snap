class PushPopFrameEvent
    attr_accessor :_message
    attr_accessor :_parameters

    def initialize(message, parameters = [])
        @_message = message
        @_parameters = parameters
    end
end


class PushPopFrameContext
    attr_accessor :_event
    attr_accessor :_return
    attr_accessor :_data
    attr_accessor :_transitioned

    def initialize(event, default_return = nil)
        @_event = event
        @_return = default_return
        @_data = {}
        @_transitioned = false
    end
end


class PushPopCompartment
    attr_accessor :state
    attr_accessor :state_args
    attr_accessor :state_vars
    attr_accessor :enter_args
    attr_accessor :exit_args
    attr_accessor :forward_event
    attr_accessor :parent_compartment

    def initialize(state, parent_compartment = nil)
        @state = state
        @state_args = []
        @state_vars = {}
        @enter_args = []
        @exit_args = []
        @forward_event = nil
        @parent_compartment = parent_compartment
    end

    def copy
        c = PushPopCompartment.new(@state, @parent_compartment)
        c.state_args = @state_args.dup
        c.state_vars = @state_vars.dup
        c.enter_args = @enter_args.dup
        c.exit_args = @exit_args.dup
        c.forward_event = @forward_event
        c
    end
end


class PushPop
    attr_accessor :_state_stack
    attr_accessor :__compartment
    attr_accessor :__next_compartment
    attr_accessor :_context_stack
    attr_accessor :pings
    attr_accessor :leaves

    def initialize
        @_state_stack = []
        @_context_stack = []
        @pings = 0
        @leaves = 0
        @__compartment = __prepareEnter("Idle", [], [])
        @__next_compartment = nil
    end

    def _frame_init
        __e = PushPopFrameEvent.new("$>", @__compartment.enter_args)
        __ctx = PushPopFrameContext.new(__e, nil)
        @_context_stack.push(__ctx)
        __kernel(__e)
        @_context_stack.pop
    end

    def self._create
        c = new
        c._frame_init()
        c
    end

    def self.hsm_chain
        {
            "Idle" => ["Idle"],
            "Nested" => ["Nested"],
        }
    end
    def __prepareEnter(leaf, state_args, enter_args)
        comp = nil
        self.class.hsm_chain[leaf].each do |name|
            new_comp = PushPopCompartment.new(name)
            new_comp.state_args = state_args.dup
            new_comp.enter_args = enter_args.dup
            new_comp.parent_compartment = comp
            comp = new_comp
        end
        comp
    end

    def __prepareExit(exit_args)
        comp = @__compartment
        while comp != nil
            comp.exit_args = exit_args.dup
            comp = comp.parent_compartment
        end
    end

    def __kernel(__e)
        # Route event to current state.
        __router(__e)
        # Drain any transitions queued by the handler.
        while @__next_compartment != nil
            next_compartment = @__next_compartment
            @__next_compartment = nil
            exit_event = PushPopFrameEvent.new("<$", @__compartment.exit_args)
            __router(exit_event)
            @__compartment = next_compartment
            forward_event = next_compartment.forward_event
            next_compartment.forward_event = nil
            if forward_event == nil
                enter_event = PushPopFrameEvent.new("$>", @__compartment.enter_args)
                __router(enter_event)
            elsif forward_event._message == "$>"
                __router(forward_event)
            else
                enter_event = PushPopFrameEvent.new("$>", @__compartment.enter_args)
                __router(enter_event)
                __router(forward_event)
            end
            @_context_stack.each { |ctx| ctx._transitioned = true }
        end
    end

    def __router(__e)
        handler_name = "_state_#{@__compartment.state}"
        if respond_to?(handler_name, true)
            send(handler_name, __e, @__compartment)
        end
    end

    def __transition(next_compartment)
        @__next_compartment = next_compartment
    end

    def ping
        __e = PushPopFrameEvent.new("ping", [])
        __ctx = PushPopFrameContext.new(__e, nil)
        @_context_stack.push(__ctx)
        __kernel(__e)
        return @_context_stack.pop._return
    end

    def nest
        __e = PushPopFrameEvent.new("nest", [])
        __ctx = PushPopFrameContext.new(__e, nil)
        @_context_stack.push(__ctx)
        __kernel(__e)
        return @_context_stack.pop._return
    end

    def unnest
        __e = PushPopFrameEvent.new("unnest", [])
        __ctx = PushPopFrameContext.new(__e, nil)
        @_context_stack.push(__ctx)
        __kernel(__e)
        return @_context_stack.pop._return
    end

    def leaf
        __e = PushPopFrameEvent.new("leaf", [])
        __ctx = PushPopFrameContext.new(__e, nil)
        @_context_stack.push(__ctx)
        __kernel(__e)
        return @_context_stack.pop._return
    end

    def _state_Idle(__e, compartment)
        if __e._message == "nest"
            self._s_Idle_hdl_user_nest(__e, compartment)
            return
        end
        if __e._message == "ping"
            self._s_Idle_hdl_user_ping(__e, compartment)
            return
        end
    end

    def _state_Nested(__e, compartment)
        if __e._message == "leaf"
            self._s_Nested_hdl_user_leaf(__e, compartment)
            return
        end
        if __e._message == "unnest"
            self._s_Nested_hdl_user_unnest(__e, compartment)
            return
        end
    end

    def _s_Idle_hdl_user_nest(__e, compartment)
        @_state_stack.push(@__compartment)
        __compartment = __prepareEnter("Nested", [], [])
        __transition(__compartment)
        return
    end

    def _s_Idle_hdl_user_ping(__e, compartment)
        self.pings = self.pings + 1
    end

    def _s_Nested_hdl_user_leaf(__e, compartment)
        self.leaves = self.leaves + 1
    end

    def _s_Nested_hdl_user_unnest(__e, compartment)
        __saved = @_state_stack.pop
        __transition(__saved)
        return
    end
end
