#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <stdbool.h>
#include <stdint.h>

// ============================================================================
// PushPop_FrameDict - String-keyed dictionary
// ============================================================================

typedef struct PushPop_FrameDictEntry {
    char* key;
    void* value;
    struct PushPop_FrameDictEntry* next;
} PushPop_FrameDictEntry;

typedef struct {
    PushPop_FrameDictEntry** buckets;
    int bucket_count;
    int size;
} PushPop_FrameDict;

static unsigned int PushPop_hash_string(const char* str) {
    unsigned int hash = 5381;
    int c;
    while ((c = *str++)) {
        hash = ((hash << 5) + hash) + c;
    }
    return hash;
}

static PushPop_FrameDict* PushPop_FrameDict_new(void) {
    PushPop_FrameDict* d = malloc(sizeof(PushPop_FrameDict));
    d->bucket_count = 16;
    d->buckets = calloc(d->bucket_count, sizeof(PushPop_FrameDictEntry*));
    d->size = 0;
    return d;
}

static void PushPop_FrameDict_set(PushPop_FrameDict* d, const char* key, void* value) {
    unsigned int idx = PushPop_hash_string(key) % d->bucket_count;
    PushPop_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            entry->value = value;
            return;
        }
        entry = entry->next;
    }
    PushPop_FrameDictEntry* new_entry = malloc(sizeof(PushPop_FrameDictEntry));
    new_entry->key = strdup(key);
    new_entry->value = value;
    new_entry->next = d->buckets[idx];
    d->buckets[idx] = new_entry;
    d->size++;
}

static void* PushPop_FrameDict_get(PushPop_FrameDict* d, const char* key) {
    unsigned int idx = PushPop_hash_string(key) % d->bucket_count;
    PushPop_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            return entry->value;
        }
        entry = entry->next;
    }
    return NULL;
}

static int PushPop_FrameDict_has(PushPop_FrameDict* d, const char* key) {
    unsigned int idx = PushPop_hash_string(key) % d->bucket_count;
    PushPop_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            return 1;
        }
        entry = entry->next;
    }
    return 0;
}

static PushPop_FrameDict* PushPop_FrameDict_copy(PushPop_FrameDict* src) {
    PushPop_FrameDict* dst = PushPop_FrameDict_new();
    for (int i = 0; i < src->bucket_count; i++) {
        PushPop_FrameDictEntry* entry = src->buckets[i];
        while (entry) {
            PushPop_FrameDict_set(dst, entry->key, entry->value);
            entry = entry->next;
        }
    }
    return dst;
}

static void PushPop_FrameDict_destroy(PushPop_FrameDict* d) {
    for (int i = 0; i < d->bucket_count; i++) {
        PushPop_FrameDictEntry* entry = d->buckets[i];
        while (entry) {
            PushPop_FrameDictEntry* next = entry->next;
            free(entry->key);
            free(entry);
            entry = next;
        }
    }
    free(d->buckets);
    free(d);
}

// ============================================================================
// PushPop_FrameVec - Dynamic array
// ============================================================================

typedef struct {
    void** items;
    int size;
    int capacity;
} PushPop_FrameVec;

static PushPop_FrameVec* PushPop_FrameVec_new(void) {
    PushPop_FrameVec* v = malloc(sizeof(PushPop_FrameVec));
    v->capacity = 8;
    v->size = 0;
    v->items = malloc(sizeof(void*) * v->capacity);
    return v;
}

static void PushPop_FrameVec_push(PushPop_FrameVec* v, void* item) {
    if (v->size >= v->capacity) {
        v->capacity *= 2;
        v->items = realloc(v->items, sizeof(void*) * v->capacity);
    }
    v->items[v->size++] = item;
}

static void* PushPop_FrameVec_pop(PushPop_FrameVec* v) {
    if (v->size == 0) return NULL;
    return v->items[--v->size];
}

static void* PushPop_FrameVec_last(PushPop_FrameVec* v) {
    if (v->size == 0) return NULL;
    return v->items[v->size - 1];
}

static void* PushPop_FrameVec_get(PushPop_FrameVec* v, int index) {
    if (index < 0 || index >= v->size) return NULL;
    return v->items[index];
}

static int PushPop_FrameVec_size(PushPop_FrameVec* v) {
    return v->size;
}

static void PushPop_FrameVec_destroy(PushPop_FrameVec* v) {
    if (!v) return;
    free(v->items);
    free(v);
}

static PushPop_FrameVec* PushPop_FrameVec_copy(PushPop_FrameVec* src) {
    if (!src) return NULL;
    PushPop_FrameVec* v = PushPop_FrameVec_new();
    for (int i = 0; i < src->size; i++) {
        PushPop_FrameVec_push(v, src->items[i]);
    }
    return v;
}

// ============================================================================
// PushPop_pack_double / PushPop_unpack_double — bit-pun doubles through void*
// ============================================================================

static inline void* PushPop_pack_double(double v) {
    void* p = 0;
    memcpy(&p, &v, sizeof(double));
    return p;
}

static inline double PushPop_unpack_double(void* p) {
    double d;
    memcpy(&d, &p, sizeof(double));
    return d;
}

// ============================================================================
// PushPop_FrameEvent - Event routing object
// ============================================================================

typedef struct {
    const char* _message;
    PushPop_FrameVec* _parameters;
    int _owns_parameters;
} PushPop_FrameEvent;

static PushPop_FrameEvent* PushPop_FrameEvent_new(const char* message, PushPop_FrameVec* parameters, int owns_parameters) {
    PushPop_FrameEvent* e = malloc(sizeof(PushPop_FrameEvent));
    e->_message = message;
    e->_parameters = parameters;
    e->_owns_parameters = owns_parameters;
    return e;
}

static void PushPop_FrameEvent_destroy(PushPop_FrameEvent* e) {
    if (e->_owns_parameters && e->_parameters) PushPop_FrameVec_destroy(e->_parameters);
    free(e);
}

// ============================================================================
// PushPop_FrameContext - Interface call context
// ============================================================================

typedef struct {
    PushPop_FrameEvent* event;
    void* _return;
    PushPop_FrameDict* _data;
    int _transitioned;
} PushPop_FrameContext;

static PushPop_FrameContext* PushPop_FrameContext_new(PushPop_FrameEvent* event, void* default_return) {
    PushPop_FrameContext* ctx = malloc(sizeof(PushPop_FrameContext));
    ctx->event = event;
    ctx->_return = default_return;
    ctx->_data = PushPop_FrameDict_new();
    ctx->_transitioned = 0;
    return ctx;
}

static void PushPop_FrameContext_destroy(PushPop_FrameContext* ctx) {
    PushPop_FrameDict_destroy(ctx->_data);
    free(ctx);
}

// ============================================================================
// PushPop_Compartment - State closure
// ============================================================================

typedef struct PushPop_Compartment {
    const char* state;
    PushPop_FrameVec* state_args;
    PushPop_FrameDict* state_vars;
    PushPop_FrameVec* enter_args;
    PushPop_FrameVec* exit_args;
    PushPop_FrameEvent* forward_event;
    struct PushPop_Compartment* parent_compartment;
    int _ref_count;
} PushPop_Compartment;

static PushPop_Compartment* PushPop_Compartment_new(const char* state) {
    PushPop_Compartment* c = malloc(sizeof(PushPop_Compartment));
    c->state = state;
    c->state_args = PushPop_FrameVec_new();
    c->state_vars = PushPop_FrameDict_new();
    c->enter_args = PushPop_FrameVec_new();
    c->exit_args = PushPop_FrameVec_new();
    c->forward_event = NULL;
    c->parent_compartment = NULL;
    c->_ref_count = 1;
    return c;
}

static PushPop_Compartment* PushPop_Compartment_ref(PushPop_Compartment* c) {
    if (c) c->_ref_count++;
    return c;
}

static void PushPop_Compartment_unref(PushPop_Compartment* c);
static void PushPop_Compartment_unref(PushPop_Compartment* c) {
    if (c == NULL) return;
    c->_ref_count--;
    if (c->_ref_count <= 0) {
        PushPop_Compartment_unref(c->parent_compartment);
        PushPop_FrameVec_destroy(c->state_args);
        PushPop_FrameDict_destroy(c->state_vars);
        PushPop_FrameVec_destroy(c->enter_args);
        PushPop_FrameVec_destroy(c->exit_args);
        free(c);
    }
}

static PushPop_Compartment* PushPop_Compartment_copy(PushPop_Compartment* src) {
    PushPop_Compartment* c = malloc(sizeof(PushPop_Compartment));
    c->state = src->state;
    c->state_args = PushPop_FrameVec_copy(src->state_args);
    c->state_vars = PushPop_FrameDict_copy(src->state_vars);
    c->enter_args = PushPop_FrameVec_copy(src->enter_args);
    c->exit_args = PushPop_FrameVec_copy(src->exit_args);
    c->forward_event = src->forward_event;  // Shallow copy OK
    c->parent_compartment = src->parent_compartment;
    return c;
}

static void PushPop_Compartment_destroy(PushPop_Compartment* c) {
    PushPop_FrameVec_destroy(c->state_args);
    PushPop_FrameDict_destroy(c->state_vars);
    PushPop_FrameVec_destroy(c->enter_args);
    PushPop_FrameVec_destroy(c->exit_args);
    free(c);
}

// Helper macros for context access
#define PushPop_CTX(self) ((PushPop_FrameContext*)PushPop_FrameVec_last((self)->_context_stack))
#define PushPop_PARAM(self, key) PushPop_FrameDict_get(PushPop_CTX(self)->event->_parameters, key)
#define PushPop_RETURN(self) PushPop_CTX(self)->_return
#define PushPop_DATA(self, key) PushPop_FrameDict_get(PushPop_CTX(self)->_data, key)
#define PushPop_DATA_SET(self, key, val) PushPop_FrameDict_set(PushPop_CTX(self)->_data, key, val)

// Forward declarations
typedef struct PushPop PushPop;
static void PushPop_kernel(PushPop* self, PushPop_FrameEvent* __e);
static void PushPop_router(PushPop* self, PushPop_FrameEvent* __e);
static void PushPop_transition(PushPop* self, PushPop_Compartment* next);
static int PushPop_hsm_chain(PushPop* self, const char* leaf, const char*** out_chain);
static PushPop_Compartment* PushPop_prepareEnter(PushPop* self, const char* leaf, PushPop_FrameVec* state_args, PushPop_FrameVec* enter_args);
static void PushPop_prepareExit(PushPop* self, PushPop_FrameVec* exit_args);
static void PushPop_state_Idle(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
static void PushPop_state_Nested(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
static void PushPop_s_Idle_hdl_user_nest(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
static void PushPop_s_Idle_hdl_user_ping(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
static void PushPop_s_Nested_hdl_user_leaf(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
static void PushPop_s_Nested_hdl_user_unnest(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment);
void PushPop_ping (PushPop* self);
void PushPop_nest (PushPop* self);
void PushPop_unnest (PushPop* self);
void PushPop_leaf (PushPop* self);

struct PushPop {
    PushPop_FrameVec* _state_stack;
    PushPop_Compartment* __compartment;
    PushPop_Compartment* __next_compartment;
    PushPop_FrameVec* _context_stack;
    i32 pings;
    i32 leaves;
};

PushPop* PushPop_new(void) {
    PushPop* self = calloc(1, sizeof(PushPop));
    self->_state_stack = PushPop_FrameVec_new();
    self->_context_stack = PushPop_FrameVec_new();
    self->pings = 0;
    self->leaves = 0;
    PushPop_FrameVec* __sa = NULL;
    PushPop_FrameVec* __ea = NULL;
    self->__compartment = PushPop_prepareEnter(self, "Idle", __sa, __ea);
    self->__next_compartment = NULL;
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("$>", self->__compartment->enter_args, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_FrameContext* __init_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__init_ctx);
    PushPop_FrameEvent_destroy(__e);
    return self;
}

PushPop* PushPop_create(void) {
    PushPop* self = PushPop_new();
    self->_state_stack = PushPop_FrameVec_new();
    self->_context_stack = PushPop_FrameVec_new();
    self->pings = 0;
    self->leaves = 0;
    PushPop_FrameVec* __sa = NULL;
    PushPop_FrameVec* __ea = NULL;
    self->__compartment = PushPop_prepareEnter(self, "Idle", __sa, __ea);
    self->__next_compartment = NULL;
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("$>", self->__compartment->enter_args, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_kernel(self, __e);
    PushPop_FrameContext* __init_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__init_ctx);
    PushPop_FrameEvent_destroy(__e);
    return self;
}

static int PushPop_hsm_chain(PushPop* self, const char* leaf, const char*** out_chain) {
    if (false) { (void)0; }
        else if (strcmp(leaf, "Idle") == 0) {
            static const char* __chain[] = { "Idle" };
            *out_chain = __chain;
            return 1;
        }
        else if (strcmp(leaf, "Nested") == 0) {
            static const char* __chain[] = { "Nested" };
            *out_chain = __chain;
            return 1;
        }
        *out_chain = NULL;
        return 0;
}

static PushPop_Compartment* PushPop_prepareEnter(PushPop* self, const char* leaf, PushPop_FrameVec* state_args, PushPop_FrameVec* enter_args) {
    const char** chain = NULL;
    int n = PushPop_hsm_chain(self, leaf, &chain);
    PushPop_Compartment* comp = NULL;
    for (int i = 0; i < n; i++) {
        PushPop_Compartment* nc = PushPop_Compartment_new(chain[i]);
        if (state_args) {
            for (int j = 0; j < state_args->size; j++) PushPop_FrameVec_push(nc->state_args, state_args->items[j]);
        }
        if (enter_args) {
            for (int j = 0; j < enter_args->size; j++) PushPop_FrameVec_push(nc->enter_args, enter_args->items[j]);
        }
        nc->parent_compartment = comp;  // adopts ref
        comp = nc;
    }
    return comp;
}

static void PushPop_prepareExit(PushPop* self, PushPop_FrameVec* exit_args) {
    PushPop_Compartment* comp = self->__compartment;
    while (comp != NULL) {
        // Clear any prior exit_args before copying the new ones in.
        while (comp->exit_args->size > 0) comp->exit_args->size--;
        if (exit_args) {
            for (int j = 0; j < exit_args->size; j++) PushPop_FrameVec_push(comp->exit_args, exit_args->items[j]);
        }
        comp = comp->parent_compartment;
    }
}

static void PushPop_kernel(PushPop* self, PushPop_FrameEvent* __e) {
    PushPop_router(self, __e);
    while (self->__next_compartment != NULL) {
        PushPop_Compartment* next_compartment = self->__next_compartment;
        self->__next_compartment = NULL;
        // Exit the current (leaf) state
        PushPop_FrameEvent* __exit_event = PushPop_FrameEvent_new("<$", self->__compartment->exit_args, 0);
        PushPop_router(self, __exit_event);
        PushPop_FrameEvent_destroy(__exit_event);
        PushPop_Compartment_unref(self->__compartment);
        self->__compartment = next_compartment;
        if (next_compartment->forward_event == NULL) {
            // No forwarded event — synthesize a fresh $>
            PushPop_FrameEvent* __enter_event = PushPop_FrameEvent_new("$>", self->__compartment->enter_args, 0);
            PushPop_router(self, __enter_event);
            PushPop_FrameEvent_destroy(__enter_event);
        } else if (strcmp(next_compartment->forward_event->_message, "$>") == 0) {
            // Forwarded event IS $> — dispatch directly so the
            // destination's $> handler receives the caller's payload.
            // The forward_event is borrowed (owned by the wrapper that
            // queued the transition) — do NOT destroy it here.
            PushPop_FrameEvent* forward_event = next_compartment->forward_event;
            next_compartment->forward_event = NULL;
            PushPop_router(self, forward_event);
        } else {
            // Forwarded event is not $> — initialize the destination
            // with a fresh $>, then dispatch the forward to it. The
            // forward_event is borrowed; only the synthesized $> belongs
            // to the kernel and is freed here.
            PushPop_FrameEvent* forward_event = next_compartment->forward_event;
            next_compartment->forward_event = NULL;
            PushPop_FrameEvent* __enter_event = PushPop_FrameEvent_new("$>", self->__compartment->enter_args, 0);
            PushPop_router(self, __enter_event);
            PushPop_FrameEvent_destroy(__enter_event);
            PushPop_router(self, forward_event);
        }
        // Mark every stacked context as having transitioned. Read by
        // @@:self.X() guard so outer self-calls short-circuit.
        for (int __i = 0; __i < self->_context_stack->size; __i++) {
            ((PushPop_FrameContext*)self->_context_stack->items[__i])->_transitioned = 1;
        }
    }
}

static void PushPop_router(PushPop* self, PushPop_FrameEvent* __e) {
    if (strcmp(self->__compartment->state, "Idle") == 0) {
        PushPop_state_Idle(self, __e, self->__compartment);
    } else if (strcmp(self->__compartment->state, "Nested") == 0) {
        PushPop_state_Nested(self, __e, self->__compartment);
    }
}

static void PushPop_transition(PushPop* self, PushPop_Compartment* next_compartment) {
    self->__next_compartment = next_compartment;
}

void PushPop_destroy(PushPop* self) {
    // Unref current compartment (may free if not on stack)
    if (self->__compartment) PushPop_Compartment_unref(self->__compartment);
    if (self->__next_compartment) PushPop_Compartment_unref(self->__next_compartment);
    // Unref all state stack entries
    if (self->_state_stack) {
        for (int __i = 0; __i < self->_state_stack->size; __i++) {
            PushPop_Compartment_unref((PushPop_Compartment*)self->_state_stack->items[__i]);
        }
        PushPop_FrameVec_destroy(self->_state_stack);
    }
    if (self->_context_stack) PushPop_FrameVec_destroy(self->_context_stack);
    free(self);
}

void PushPop_ping(PushPop* self) {
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("ping", NULL, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_kernel(self, __e);
    PushPop_FrameContext* __result_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__result_ctx);
    PushPop_FrameEvent_destroy(__e);
}

void PushPop_nest(PushPop* self) {
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("nest", NULL, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_kernel(self, __e);
    PushPop_FrameContext* __result_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__result_ctx);
    PushPop_FrameEvent_destroy(__e);
}

void PushPop_unnest(PushPop* self) {
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("unnest", NULL, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_kernel(self, __e);
    PushPop_FrameContext* __result_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__result_ctx);
    PushPop_FrameEvent_destroy(__e);
}

void PushPop_leaf(PushPop* self) {
    PushPop_FrameEvent* __e = PushPop_FrameEvent_new("leaf", NULL, 0);
    PushPop_FrameContext* __ctx = PushPop_FrameContext_new(__e, NULL);
    PushPop_FrameVec_push(self->_context_stack, __ctx);
    PushPop_kernel(self, __e);
    PushPop_FrameContext* __result_ctx = (PushPop_FrameContext*)PushPop_FrameVec_pop(self->_context_stack);
    PushPop_FrameContext_destroy(__result_ctx);
    PushPop_FrameEvent_destroy(__e);
}

static void PushPop_state_Idle(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    if (strcmp(__e->_message, "nest") == 0) {
        PushPop_s_Idle_hdl_user_nest(self, __e, compartment);
        return;
    }
    if (strcmp(__e->_message, "ping") == 0) {
        PushPop_s_Idle_hdl_user_ping(self, __e, compartment);
        return;
    }
}

static void PushPop_state_Nested(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    if (strcmp(__e->_message, "leaf") == 0) {
        PushPop_s_Nested_hdl_user_leaf(self, __e, compartment);
        return;
    }
    if (strcmp(__e->_message, "unnest") == 0) {
        PushPop_s_Nested_hdl_user_unnest(self, __e, compartment);
        return;
    }
}

static void PushPop_s_Idle_hdl_user_nest(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    PushPop_FrameVec_push(self->_state_stack, PushPop_Compartment_ref(self->__compartment));
    {
        PushPop_FrameVec* __sa = NULL;
        PushPop_FrameVec* __ea = NULL;
        PushPop_Compartment* __compartment = PushPop_prepareEnter(self, "Nested", __sa, __ea);
        PushPop_transition(self, __compartment);
    }
    return;
}

static void PushPop_s_Idle_hdl_user_ping(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    self.pings = self.pings + 1
}

static void PushPop_s_Nested_hdl_user_leaf(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    self.leaves = self.leaves + 1
}

static void PushPop_s_Nested_hdl_user_unnest(PushPop* self, PushPop_FrameEvent* __e, PushPop_Compartment* compartment) {
    PushPop_Compartment* __saved = (PushPop_Compartment*)PushPop_FrameVec_pop(self->_state_stack);
    PushPop_transition(self, __saved);
    return;
}
