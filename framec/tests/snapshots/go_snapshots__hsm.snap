func (s *MiniHsm) _s_Asleep_hdl_user_wake(__e *MiniHsmFrameEvent, compartment *MiniHsmCompartment) {
    {
    __compartment := s.__prepareEnter("Awake", []any{}, []any{})
    s.__transition(__compartment)
    return
    }
