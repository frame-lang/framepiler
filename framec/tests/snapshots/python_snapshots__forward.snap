from typing import Any, Optional, List, Dict, Callable

class ForwardFrameEvent:
    def __init__(self, message: str, parameters):
        self._message = message
        self._parameters = parameters


class ForwardFrameContext:
    def __init__(self, event: ForwardFrameEvent, default_return):
        self.event = event
        self._return = default_return
        self._data = {}
        self._transitioned = False


class ForwardCompartment:
    def __init__(self, state: str, parent_compartment = None):
        self.state = state
        self.state_args = []
        self.state_vars = {}
        self.enter_args = []
        self.exit_args = []
        self.forward_event = None
        self.parent_compartment = parent_compartment

    def copy(self) -> 'ForwardCompartment':
        c = ForwardCompartment(self.state, self.parent_compartment)
        c.state_args = self.state_args.copy()
        c.state_vars = self.state_vars.copy()
        c.enter_args = self.enter_args.copy()
        c.exit_args = self.exit_args.copy()
        c.forward_event = self.forward_event
        return c


class Forward:
    def __init__(self):
        self._state_stack = []
        self._context_stack = []
        self.starts = 0
        self.middles = 0
        self.__compartment = self.__prepareEnter("Start", [], [])
        self.__next_compartment = None

    @classmethod
    def _create(cls):
        c = cls()
        __e = ForwardFrameEvent("$>", c.__compartment.enter_args)
        __ctx = ForwardFrameContext(__e, None)
        c._context_stack.append(__ctx)
        c.__kernel(__e)
        c._context_stack.pop()
        return c

    _HSM_CHAIN = {
        "Start": ["Start"],
        "Middle": ["Middle"],
        "End": ["End"],
    }
    def __prepareEnter(self, leaf, state_args, enter_args):
        comp = None
        for name in self._HSM_CHAIN[leaf]:
            new_comp = ForwardCompartment(name)
            new_comp.state_args = list(state_args)
            new_comp.enter_args = list(enter_args)
            new_comp.parent_compartment = comp
            comp = new_comp
        return comp

    def __prepareExit(self, exit_args):
        comp = self.__compartment
        while comp is not None:
            comp.exit_args = list(exit_args)
            comp = comp.parent_compartment

    def __kernel(self, __e):
        # Route event to current state
        self.__router(__e)
        # Drain any transitions queued by the handler
        while self.__next_compartment is not None:
            next_compartment = self.__next_compartment
            self.__next_compartment = None
            # Exit the current (leaf) state
            self.__router(ForwardFrameEvent("<$", self.__compartment.exit_args))
            # Switch to the new compartment
            self.__compartment = next_compartment
            if next_compartment.forward_event is None:
                # No forwarded event — synthesize a fresh $>
                self.__router(ForwardFrameEvent("$>", self.__compartment.enter_args))
            else:
                if next_compartment.forward_event._message == "$>":
                    # Forwarded event IS $> — dispatch directly so the
                    # destination's $> receives the caller's payload
                    self.__router(next_compartment.forward_event)
                else:
                    # Forwarded event is not $> — initialize the destination
                    # with a fresh $>, then dispatch the forward to it
                    self.__router(ForwardFrameEvent("$>", self.__compartment.enter_args))
                    self.__router(next_compartment.forward_event)
            next_compartment.forward_event = None
            # Mark all stacked contexts as transitioned
            for ctx in self._context_stack:
                ctx._transitioned = True

    def __router(self, __e):
        if self.__compartment.state == "Start":
            self._state_Start(__e, self.__compartment)
        elif self.__compartment.state == "Middle":
            self._state_Middle(__e, self.__compartment)
        elif self.__compartment.state == "End":
            self._state_End(__e, self.__compartment)

    def __transition(self, next_compartment):
        self.__next_compartment = next_compartment

    def run(self):
        __e = ForwardFrameEvent("run", [])
        __ctx = ForwardFrameContext(__e, None)
        self._context_stack.append(__ctx)
        self.__kernel(__e)
        return self._context_stack.pop()._return

    def finish(self):
        __e = ForwardFrameEvent("finish", [])
        __ctx = ForwardFrameContext(__e, None)
        self._context_stack.append(__ctx)
        self.__kernel(__e)
        return self._context_stack.pop()._return

    def _state_Start(self, __e, compartment):
        if __e._message == "run":
            self._s_Start_hdl_user_run(__e, compartment)
            return

    def _state_Middle(self, __e, compartment):
        if __e._message == "finish":
            self._s_Middle_hdl_user_finish(__e, compartment)
            return
        if __e._message == "run":
            self._s_Middle_hdl_user_run(__e, compartment)
            return

    def _state_End(self, __e, compartment):
        if __e._message == "finish":
            self._s_End_hdl_user_finish(__e, compartment)
            return

    def _s_Start_hdl_user_run(self, __e, compartment):
        self.starts = self.starts + 1
        __compartment = self.__prepareEnter("Middle", [], [])
        __compartment.forward_event = __e
        self.__transition(__compartment)
        return

    def _s_Middle_hdl_user_finish(self, __e, compartment):
        __compartment = self.__prepareEnter("End", [], [])
        self.__transition(__compartment)
        return

    def _s_Middle_hdl_user_run(self, __e, compartment):
        self.middles = self.middles + 1

    def _s_End_hdl_user_finish(self, __e, compartment):
        pass
