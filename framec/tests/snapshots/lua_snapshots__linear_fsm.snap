local LinearFsmFrameEvent = {}
LinearFsmFrameEvent.__index = LinearFsmFrameEvent

function LinearFsmFrameEvent.new(message, parameters)
    local self = setmetatable({}, LinearFsmFrameEvent)
    self._message = message
    self._parameters = parameters or {}
    return self
end


local LinearFsmFrameContext = {}
LinearFsmFrameContext.__index = LinearFsmFrameContext

function LinearFsmFrameContext.new(event, default_return)
    local self = setmetatable({}, LinearFsmFrameContext)
    self._event = event
    self._return = default_return
    self._data = {}
    self._transitioned = false
    return self
end


local LinearFsmCompartment = {}
LinearFsmCompartment.__index = LinearFsmCompartment

function LinearFsmCompartment.new(state, parent_compartment)
    local self = setmetatable({}, LinearFsmCompartment)
    self.state = state
    self.state_args = {}
    self.state_vars = {}
    self.enter_args = {}
    self.exit_args = {}
    self.forward_event = nil
    self.parent_compartment = parent_compartment
    return self
end

function LinearFsmCompartment:copy()
    local c = LinearFsmCompartment.new(self.state, self.parent_compartment)
    c.state_args = {}
    for k, v in pairs(self.state_args) do c.state_args[k] = v end
    c.state_vars = {}
    for k, v in pairs(self.state_vars) do c.state_vars[k] = v end
    c.enter_args = {}
    for k, v in pairs(self.enter_args) do c.enter_args[k] = v end
    c.exit_args = {}
    for k, v in pairs(self.exit_args) do c.exit_args[k] = v end
    c.forward_event = self.forward_event
    return c
end


local LinearFsm = {}
LinearFsm.__index = LinearFsm

function LinearFsm.new()
    local self = setmetatable({}, LinearFsm)
    self._state_stack = {}
    self._context_stack = {}
    self.total = 0
    self.__compartment = self:__prepareEnter("Idle", nil, nil)
    self.__next_compartment = nil
    return self
end

function LinearFsm:_frame_init()
    local __e = LinearFsmFrameEvent.new("$>", self.__compartment.enter_args)
    local __ctx = LinearFsmFrameContext.new(__e, nil)
    self._context_stack[#self._context_stack + 1] = __ctx
    self:__kernel(__e)
    table.remove(self._context_stack)
end

function LinearFsm._create()
    local c = LinearFsm.new()
    c:_frame_init()
    return c
end

function LinearFsm:hsm_chain()
    local t = {}
    t["Idle"] = {"Idle"}
    t["Active"] = {"Active"}
    t["Done"] = {"Done"}
    return t
end
function LinearFsm:__prepareEnter(leaf, state_args, enter_args)
    state_args = state_args or {}
    enter_args = enter_args or {}
    local comp = nil
    local chain = self:hsm_chain()[leaf]
    for i = 1, #chain do
        local new_comp = LinearFsmCompartment.new(chain[i])
        new_comp.state_args = {}
        for j = 1, #state_args do new_comp.state_args[j] = state_args[j] end
        new_comp.enter_args = {}
        for j = 1, #enter_args do new_comp.enter_args[j] = enter_args[j] end
        new_comp.parent_compartment = comp
        comp = new_comp
    end
    return comp
end

function LinearFsm:__prepareExit(exit_args)
    local comp = self.__compartment
    while comp ~= nil do
        comp.exit_args = {}
        for j = 1, #exit_args do comp.exit_args[j] = exit_args[j] end
        comp = comp.parent_compartment
    end
end

function LinearFsm:__kernel(__e)
    -- Route event to current state.
    self:__router(__e)
    -- Drain any transitions queued by the handler.
    while self.__next_compartment ~= nil do
        local next_compartment = self.__next_compartment
        self.__next_compartment = nil
        local exit_event = LinearFsmFrameEvent.new("<$", self.__compartment.exit_args)
        self:__router(exit_event)
        self.__compartment = next_compartment
        local forward_event = next_compartment.forward_event
        next_compartment.forward_event = nil
        if forward_event == nil then
            local enter_event = LinearFsmFrameEvent.new("$>", self.__compartment.enter_args)
            self:__router(enter_event)
        elseif forward_event._message == "$>" then
            self:__router(forward_event)
        else
            local enter_event = LinearFsmFrameEvent.new("$>", self.__compartment.enter_args)
            self:__router(enter_event)
            self:__router(forward_event)
        end
        for _, ctx in ipairs(self._context_stack) do
            ctx._transitioned = true
        end
    end
end

function LinearFsm:__router(__e)
    local handler = self["_state_" .. self.__compartment.state]
    if handler then
        handler(self, __e, self.__compartment)
    end
end

function LinearFsm:__transition(next_compartment)
    self.__next_compartment = next_compartment
end

function LinearFsm:start()
    local __e = LinearFsmFrameEvent.new("start", {})
    local __ctx = LinearFsmFrameContext.new(__e, nil)
    self._context_stack[#self._context_stack + 1] = __ctx
    self:__kernel(__e)
    return table.remove(self._context_stack)._return
end

function LinearFsm:progress(amount)
    local __e = LinearFsmFrameEvent.new("progress", {amount})
    local __ctx = LinearFsmFrameContext.new(__e, nil)
    self._context_stack[#self._context_stack + 1] = __ctx
    self:__kernel(__e)
    return table.remove(self._context_stack)._return
end

function LinearFsm:finish()
    local __e = LinearFsmFrameEvent.new("finish", {})
    local __ctx = LinearFsmFrameContext.new(__e, nil)
    self._context_stack[#self._context_stack + 1] = __ctx
    self:__kernel(__e)
    return table.remove(self._context_stack)._return
end

function LinearFsm:_state_Idle(__e, compartment)
    if __e._message == "start" then
        self:_s_Idle_hdl_user_start(__e, compartment)
        return
    end
end

function LinearFsm:_state_Active(__e, compartment)
    if __e._message == "finish" then
        self:_s_Active_hdl_user_finish(__e, compartment)
        return
    end
    if __e._message == "progress" then
        self:_s_Active_hdl_user_progress(__e, compartment)
        return
    end
end

function LinearFsm:_state_Done(__e, compartment)

end

function LinearFsm:_s_Idle_hdl_user_start(__e, compartment)
    local __compartment = self:__prepareEnter("Active", nil, nil)
    self:__transition(__compartment)
    return
end

function LinearFsm:_s_Active_hdl_user_finish(__e, compartment)
    local __compartment = self:__prepareEnter("Done", nil, nil)
    self:__transition(__compartment)
    return
end

function LinearFsm:_s_Active_hdl_user_progress(__e, compartment)
    local amount = __e._parameters[1]
    // self mutation exercised below via domain field
    self.total = self.total + amount
end
