type NoPersistFrameEvent struct {
    _message    string
    _parameters []any
}

type NoPersistFrameContext struct {
    _event  NoPersistFrameEvent
    _return       any
    _data         map[string]any
    _transitioned bool
}

type NoPersistCompartment struct {
    state            string
    stateArgs        []any
    stateVars        map[string]any
    enterArgs        []any
    exitArgs         []any
    forwardEvent     *NoPersistFrameEvent
    parentCompartment *NoPersistCompartment
}

func newNoPersistCompartment(state string) *NoPersistCompartment {
    return &NoPersistCompartment{
        state:    state,
        stateArgs: []any{},
        stateVars: make(map[string]any),
        enterArgs: []any{},
        exitArgs:  []any{},
    }
}

func (c *NoPersistCompartment) copy() *NoPersistCompartment {
    nc := &NoPersistCompartment{
        state: c.state,
        stateArgs: append([]any{}, c.stateArgs...),
        stateVars: make(map[string]any),
        enterArgs: append([]any{}, c.enterArgs...),
        exitArgs:  append([]any{}, c.exitArgs...),
        forwardEvent:     c.forwardEvent,
        parentCompartment: c.parentCompartment,
    }
    for k, v := range c.stateVars { nc.stateVars[k] = v }
    return nc
}

type NoPersist struct {
    _state_stack []*NoPersistCompartment
    __compartment *NoPersistCompartment
    __next_compartment *NoPersistCompartment
    _context_stack []NoPersistFrameContext
    count int
    cache int
}

func NewNoPersist() *NoPersist {
    s := &NoPersist{}
    s._state_stack = make([]*NoPersistCompartment, 0)
    s._context_stack = make([]NoPersistFrameContext, 0)
    s.count = 0
    s.cache = -1
    s.__compartment = s.__prepareEnter("Active", []any{}, []any{})
    s.__next_compartment = nil
    return s
}

func CreateNoPersist() *NoPersist {
    c := NewNoPersist()
    __e := NoPersistFrameEvent{_message: "$>", _parameters: c.__compartment.enterArgs}
    __ctx := NoPersistFrameContext{_event: __e, _data: make(map[string]any)}
    c._context_stack = append(c._context_stack, __ctx)
    c.__kernel(&c._context_stack[len(c._context_stack)-1]._event)
    c._context_stack = c._context_stack[:len(c._context_stack)-1]
    return c
}

func (s *NoPersist) hsm_chain() map[string][]string {
    return map[string][]string{
        "Active": {"Active"},
    }
}
func (s *NoPersist) __prepareEnter(leaf string, state_args []any, enter_args []any) *NoPersistCompartment {
    var comp *NoPersistCompartment = nil
    for _, name := range s.hsm_chain()[leaf] {
        new_comp := newNoPersistCompartment(name)
        new_comp.stateArgs = append([]any{}, state_args...)
        new_comp.enterArgs = append([]any{}, enter_args...)
        new_comp.parentCompartment = comp
        comp = new_comp
    }
    return comp
}

func (s *NoPersist) __prepareExit(exit_args []any) {
    comp := s.__compartment
    for comp != nil {
        comp.exitArgs = append([]any{}, exit_args...)
        comp = comp.parentCompartment
    }
    _ = comp
}

func (s *NoPersist) __kernel(__e *NoPersistFrameEvent) {
    // Route event to current state.
    s.__router(__e)
    // Drain any transitions queued by the handler.
    for s.__next_compartment != nil {
        next_compartment := s.__next_compartment
        s.__next_compartment = nil
        // Exit the current (leaf) state.
        exit_event := &NoPersistFrameEvent{_message: "<$", _parameters: s.__compartment.exitArgs}
        s.__router(exit_event)
        // Switch to the new compartment.
        s.__compartment = next_compartment
        // Three-branch forward-event handling.
        forward_event := next_compartment.forwardEvent
        next_compartment.forwardEvent = nil
        if forward_event == nil {
            // No forwarded event — synthesize a fresh $>.
            enter_event := &NoPersistFrameEvent{_message: "$>", _parameters: s.__compartment.enterArgs}
            s.__router(enter_event)
        } else if forward_event._message == "$>" {
            // Forwarded event IS $> — dispatch directly so the
            // destination's $> handler receives the caller's payload.
            s.__router(forward_event)
        } else {
            // Forwarded event is not $> — initialize the destination
            // with a fresh $>, then dispatch the forward.
            enter_event := &NoPersistFrameEvent{_message: "$>", _parameters: s.__compartment.enterArgs}
            s.__router(enter_event)
            s.__router(forward_event)
        }
        for i := range s._context_stack {
            s._context_stack[i]._transitioned = true
        }
    }
}

func (s *NoPersist) __router(__e *NoPersistFrameEvent) {
    switch s.__compartment.state {
    case "Active":
        s._state_Active(__e, s.__compartment)
    }
}

func (s *NoPersist) __transition(next *NoPersistCompartment) {
    s.__next_compartment = next
}

