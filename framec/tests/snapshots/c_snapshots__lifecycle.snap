#include <stdlib.h>
#include <string.h>
#include <stdio.h>
#include <stdbool.h>
#include <stdint.h>

// ============================================================================
// Lifecycle_FrameDict - String-keyed dictionary
// ============================================================================

typedef struct Lifecycle_FrameDictEntry {
    char* key;
    void* value;
    struct Lifecycle_FrameDictEntry* next;
} Lifecycle_FrameDictEntry;

typedef struct {
    Lifecycle_FrameDictEntry** buckets;
    int bucket_count;
    int size;
} Lifecycle_FrameDict;

static unsigned int Lifecycle_hash_string(const char* str) {
    unsigned int hash = 5381;
    int c;
    while ((c = *str++)) {
        hash = ((hash << 5) + hash) + c;
    }
    return hash;
}

static Lifecycle_FrameDict* Lifecycle_FrameDict_new(void) {
    Lifecycle_FrameDict* d = malloc(sizeof(Lifecycle_FrameDict));
    d->bucket_count = 16;
    d->buckets = calloc(d->bucket_count, sizeof(Lifecycle_FrameDictEntry*));
    d->size = 0;
    return d;
}

static void Lifecycle_FrameDict_set(Lifecycle_FrameDict* d, const char* key, void* value) {
    unsigned int idx = Lifecycle_hash_string(key) % d->bucket_count;
    Lifecycle_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            entry->value = value;
            return;
        }
        entry = entry->next;
    }
    Lifecycle_FrameDictEntry* new_entry = malloc(sizeof(Lifecycle_FrameDictEntry));
    new_entry->key = strdup(key);
    new_entry->value = value;
    new_entry->next = d->buckets[idx];
    d->buckets[idx] = new_entry;
    d->size++;
}

static void* Lifecycle_FrameDict_get(Lifecycle_FrameDict* d, const char* key) {
    unsigned int idx = Lifecycle_hash_string(key) % d->bucket_count;
    Lifecycle_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            return entry->value;
        }
        entry = entry->next;
    }
    return NULL;
}

static int Lifecycle_FrameDict_has(Lifecycle_FrameDict* d, const char* key) {
    unsigned int idx = Lifecycle_hash_string(key) % d->bucket_count;
    Lifecycle_FrameDictEntry* entry = d->buckets[idx];
    while (entry) {
        if (strcmp(entry->key, key) == 0) {
            return 1;
        }
        entry = entry->next;
    }
    return 0;
}

static Lifecycle_FrameDict* Lifecycle_FrameDict_copy(Lifecycle_FrameDict* src) {
    Lifecycle_FrameDict* dst = Lifecycle_FrameDict_new();
    for (int i = 0; i < src->bucket_count; i++) {
        Lifecycle_FrameDictEntry* entry = src->buckets[i];
        while (entry) {
            Lifecycle_FrameDict_set(dst, entry->key, entry->value);
            entry = entry->next;
        }
    }
    return dst;
}

static void Lifecycle_FrameDict_destroy(Lifecycle_FrameDict* d) {
    for (int i = 0; i < d->bucket_count; i++) {
        Lifecycle_FrameDictEntry* entry = d->buckets[i];
        while (entry) {
            Lifecycle_FrameDictEntry* next = entry->next;
            free(entry->key);
            free(entry);
            entry = next;
        }
    }
    free(d->buckets);
    free(d);
}

// ============================================================================
// Lifecycle_FrameVec - Dynamic array
// ============================================================================

typedef struct {
    void** items;
    int size;
    int capacity;
} Lifecycle_FrameVec;

static Lifecycle_FrameVec* Lifecycle_FrameVec_new(void) {
    Lifecycle_FrameVec* v = malloc(sizeof(Lifecycle_FrameVec));
    v->capacity = 8;
    v->size = 0;
    v->items = malloc(sizeof(void*) * v->capacity);
    return v;
}

static void Lifecycle_FrameVec_push(Lifecycle_FrameVec* v, void* item) {
    if (v->size >= v->capacity) {
        v->capacity *= 2;
        v->items = realloc(v->items, sizeof(void*) * v->capacity);
    }
    v->items[v->size++] = item;
}

static void* Lifecycle_FrameVec_pop(Lifecycle_FrameVec* v) {
    if (v->size == 0) return NULL;
    return v->items[--v->size];
}

static void* Lifecycle_FrameVec_last(Lifecycle_FrameVec* v) {
    if (v->size == 0) return NULL;
    return v->items[v->size - 1];
}

static void* Lifecycle_FrameVec_get(Lifecycle_FrameVec* v, int index) {
    if (index < 0 || index >= v->size) return NULL;
    return v->items[index];
}

static int Lifecycle_FrameVec_size(Lifecycle_FrameVec* v) {
    return v->size;
}

static void Lifecycle_FrameVec_destroy(Lifecycle_FrameVec* v) {
    if (!v) return;
    free(v->items);
    free(v);
}

static Lifecycle_FrameVec* Lifecycle_FrameVec_copy(Lifecycle_FrameVec* src) {
    if (!src) return NULL;
    Lifecycle_FrameVec* v = Lifecycle_FrameVec_new();
    for (int i = 0; i < src->size; i++) {
        Lifecycle_FrameVec_push(v, src->items[i]);
    }
    return v;
}

// ============================================================================
// Lifecycle_pack_double / Lifecycle_unpack_double — bit-pun doubles through void*
// ============================================================================

static inline void* Lifecycle_pack_double(double v) {
    void* p = 0;
    memcpy(&p, &v, sizeof(double));
    return p;
}

static inline double Lifecycle_unpack_double(void* p) {
    double d;
    memcpy(&d, &p, sizeof(double));
    return d;
}

// ============================================================================
// Lifecycle_FrameEvent - Event routing object
// ============================================================================

typedef struct {
    const char* _message;
    Lifecycle_FrameVec* _parameters;
    int _owns_parameters;
} Lifecycle_FrameEvent;

static Lifecycle_FrameEvent* Lifecycle_FrameEvent_new(const char* message, Lifecycle_FrameVec* parameters, int owns_parameters) {
    Lifecycle_FrameEvent* e = malloc(sizeof(Lifecycle_FrameEvent));
    e->_message = message;
    e->_parameters = parameters;
    e->_owns_parameters = owns_parameters;
    return e;
}

static void Lifecycle_FrameEvent_destroy(Lifecycle_FrameEvent* e) {
    if (e->_owns_parameters && e->_parameters) Lifecycle_FrameVec_destroy(e->_parameters);
    free(e);
}

// ============================================================================
// Lifecycle_FrameContext - Interface call context
// ============================================================================

typedef struct {
    Lifecycle_FrameEvent* event;
    void* _return;
    Lifecycle_FrameDict* _data;
    int _transitioned;
} Lifecycle_FrameContext;

static Lifecycle_FrameContext* Lifecycle_FrameContext_new(Lifecycle_FrameEvent* event, void* default_return) {
    Lifecycle_FrameContext* ctx = malloc(sizeof(Lifecycle_FrameContext));
    ctx->event = event;
    ctx->_return = default_return;
    ctx->_data = Lifecycle_FrameDict_new();
    ctx->_transitioned = 0;
    return ctx;
}

static void Lifecycle_FrameContext_destroy(Lifecycle_FrameContext* ctx) {
    Lifecycle_FrameDict_destroy(ctx->_data);
    free(ctx);
}

// ============================================================================
// Lifecycle_Compartment - State closure
// ============================================================================

typedef struct Lifecycle_Compartment {
    const char* state;
    Lifecycle_FrameVec* state_args;
    Lifecycle_FrameDict* state_vars;
    Lifecycle_FrameVec* enter_args;
    Lifecycle_FrameVec* exit_args;
    Lifecycle_FrameEvent* forward_event;
    struct Lifecycle_Compartment* parent_compartment;
    int _ref_count;
} Lifecycle_Compartment;

static Lifecycle_Compartment* Lifecycle_Compartment_new(const char* state) {
    Lifecycle_Compartment* c = malloc(sizeof(Lifecycle_Compartment));
    c->state = state;
    c->state_args = Lifecycle_FrameVec_new();
    c->state_vars = Lifecycle_FrameDict_new();
    c->enter_args = Lifecycle_FrameVec_new();
    c->exit_args = Lifecycle_FrameVec_new();
    c->forward_event = NULL;
    c->parent_compartment = NULL;
    c->_ref_count = 1;
    return c;
}

static Lifecycle_Compartment* Lifecycle_Compartment_ref(Lifecycle_Compartment* c) {
    if (c) c->_ref_count++;
    return c;
}

static void Lifecycle_Compartment_unref(Lifecycle_Compartment* c);
static void Lifecycle_Compartment_unref(Lifecycle_Compartment* c) {
    if (c == NULL) return;
    c->_ref_count--;
    if (c->_ref_count <= 0) {
        Lifecycle_Compartment_unref(c->parent_compartment);
        Lifecycle_FrameVec_destroy(c->state_args);
        Lifecycle_FrameDict_destroy(c->state_vars);
        Lifecycle_FrameVec_destroy(c->enter_args);
        Lifecycle_FrameVec_destroy(c->exit_args);
        free(c);
    }
}

static Lifecycle_Compartment* Lifecycle_Compartment_copy(Lifecycle_Compartment* src) {
    Lifecycle_Compartment* c = malloc(sizeof(Lifecycle_Compartment));
    c->state = src->state;
    c->state_args = Lifecycle_FrameVec_copy(src->state_args);
    c->state_vars = Lifecycle_FrameDict_copy(src->state_vars);
    c->enter_args = Lifecycle_FrameVec_copy(src->enter_args);
    c->exit_args = Lifecycle_FrameVec_copy(src->exit_args);
    c->forward_event = src->forward_event;  // Shallow copy OK
    c->parent_compartment = src->parent_compartment;
    return c;
}

static void Lifecycle_Compartment_destroy(Lifecycle_Compartment* c) {
    Lifecycle_FrameVec_destroy(c->state_args);
    Lifecycle_FrameDict_destroy(c->state_vars);
    Lifecycle_FrameVec_destroy(c->enter_args);
    Lifecycle_FrameVec_destroy(c->exit_args);
    free(c);
}

// Helper macros for context access
#define Lifecycle_CTX(self) ((Lifecycle_FrameContext*)Lifecycle_FrameVec_last((self)->_context_stack))
#define Lifecycle_PARAM(self, key) Lifecycle_FrameDict_get(Lifecycle_CTX(self)->event->_parameters, key)
#define Lifecycle_RETURN(self) Lifecycle_CTX(self)->_return
#define Lifecycle_DATA(self, key) Lifecycle_FrameDict_get(Lifecycle_CTX(self)->_data, key)
#define Lifecycle_DATA_SET(self, key, val) Lifecycle_FrameDict_set(Lifecycle_CTX(self)->_data, key, val)

// Forward declarations
typedef struct Lifecycle Lifecycle;
static void Lifecycle_kernel(Lifecycle* self, Lifecycle_FrameEvent* __e);
static void Lifecycle_router(Lifecycle* self, Lifecycle_FrameEvent* __e);
static void Lifecycle_transition(Lifecycle* self, Lifecycle_Compartment* next);
static int Lifecycle_hsm_chain(Lifecycle* self, const char* leaf, const char*** out_chain);
static Lifecycle_Compartment* Lifecycle_prepareEnter(Lifecycle* self, const char* leaf, Lifecycle_FrameVec* state_args, Lifecycle_FrameVec* enter_args);
static void Lifecycle_prepareExit(Lifecycle* self, Lifecycle_FrameVec* exit_args);
static void Lifecycle_state_Idle(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
static void Lifecycle_state_Running(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
static void Lifecycle_s_Idle_hdl_user_start(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
static void Lifecycle_s_Running_hdl_frame_exit(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
static void Lifecycle_s_Running_hdl_frame_enter(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
static void Lifecycle_s_Running_hdl_user_stop(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment);
void Lifecycle_start (Lifecycle* self, char* label);
void Lifecycle_stop (Lifecycle* self);

struct Lifecycle {
    Lifecycle_FrameVec* _state_stack;
    Lifecycle_Compartment* __compartment;
    Lifecycle_Compartment* __next_compartment;
    Lifecycle_FrameVec* _context_stack;
    i32 entered;
    i32 exited;
    char* tag;
};

Lifecycle* Lifecycle_new(void) {
    Lifecycle* self = calloc(1, sizeof(Lifecycle));
    self->_state_stack = Lifecycle_FrameVec_new();
    self->_context_stack = Lifecycle_FrameVec_new();
    self->entered = 0;
    self->exited = 0;
    self->tag = "";
    Lifecycle_FrameVec* __sa = NULL;
    Lifecycle_FrameVec* __ea = NULL;
    self->__compartment = Lifecycle_prepareEnter(self, "Idle", __sa, __ea);
    self->__next_compartment = NULL;
    Lifecycle_FrameEvent* __e = Lifecycle_FrameEvent_new("$>", self->__compartment->enter_args, 0);
    Lifecycle_FrameContext* __ctx = Lifecycle_FrameContext_new(__e, NULL);
    Lifecycle_FrameVec_push(self->_context_stack, __ctx);
    Lifecycle_FrameContext* __init_ctx = (Lifecycle_FrameContext*)Lifecycle_FrameVec_pop(self->_context_stack);
    Lifecycle_FrameContext_destroy(__init_ctx);
    Lifecycle_FrameEvent_destroy(__e);
    return self;
}

Lifecycle* Lifecycle_create(void) {
    Lifecycle* self = Lifecycle_new();
    self->_state_stack = Lifecycle_FrameVec_new();
    self->_context_stack = Lifecycle_FrameVec_new();
    self->entered = 0;
    self->exited = 0;
    self->tag = "";
    Lifecycle_FrameVec* __sa = NULL;
    Lifecycle_FrameVec* __ea = NULL;
    self->__compartment = Lifecycle_prepareEnter(self, "Idle", __sa, __ea);
    self->__next_compartment = NULL;
    Lifecycle_FrameEvent* __e = Lifecycle_FrameEvent_new("$>", self->__compartment->enter_args, 0);
    Lifecycle_FrameContext* __ctx = Lifecycle_FrameContext_new(__e, NULL);
    Lifecycle_FrameVec_push(self->_context_stack, __ctx);
    Lifecycle_kernel(self, __e);
    Lifecycle_FrameContext* __init_ctx = (Lifecycle_FrameContext*)Lifecycle_FrameVec_pop(self->_context_stack);
    Lifecycle_FrameContext_destroy(__init_ctx);
    Lifecycle_FrameEvent_destroy(__e);
    return self;
}

static int Lifecycle_hsm_chain(Lifecycle* self, const char* leaf, const char*** out_chain) {
    if (false) { (void)0; }
        else if (strcmp(leaf, "Idle") == 0) {
            static const char* __chain[] = { "Idle" };
            *out_chain = __chain;
            return 1;
        }
        else if (strcmp(leaf, "Running") == 0) {
            static const char* __chain[] = { "Running" };
            *out_chain = __chain;
            return 1;
        }
        *out_chain = NULL;
        return 0;
}

static Lifecycle_Compartment* Lifecycle_prepareEnter(Lifecycle* self, const char* leaf, Lifecycle_FrameVec* state_args, Lifecycle_FrameVec* enter_args) {
    const char** chain = NULL;
    int n = Lifecycle_hsm_chain(self, leaf, &chain);
    Lifecycle_Compartment* comp = NULL;
    for (int i = 0; i < n; i++) {
        Lifecycle_Compartment* nc = Lifecycle_Compartment_new(chain[i]);
        if (state_args) {
            for (int j = 0; j < state_args->size; j++) Lifecycle_FrameVec_push(nc->state_args, state_args->items[j]);
        }
        if (enter_args) {
            for (int j = 0; j < enter_args->size; j++) Lifecycle_FrameVec_push(nc->enter_args, enter_args->items[j]);
        }
        nc->parent_compartment = comp;  // adopts ref
        comp = nc;
    }
    return comp;
}

static void Lifecycle_prepareExit(Lifecycle* self, Lifecycle_FrameVec* exit_args) {
    Lifecycle_Compartment* comp = self->__compartment;
    while (comp != NULL) {
        // Clear any prior exit_args before copying the new ones in.
        while (comp->exit_args->size > 0) comp->exit_args->size--;
        if (exit_args) {
            for (int j = 0; j < exit_args->size; j++) Lifecycle_FrameVec_push(comp->exit_args, exit_args->items[j]);
        }
        comp = comp->parent_compartment;
    }
}

static void Lifecycle_kernel(Lifecycle* self, Lifecycle_FrameEvent* __e) {
    Lifecycle_router(self, __e);
    while (self->__next_compartment != NULL) {
        Lifecycle_Compartment* next_compartment = self->__next_compartment;
        self->__next_compartment = NULL;
        // Exit the current (leaf) state
        Lifecycle_FrameEvent* __exit_event = Lifecycle_FrameEvent_new("<$", self->__compartment->exit_args, 0);
        Lifecycle_router(self, __exit_event);
        Lifecycle_FrameEvent_destroy(__exit_event);
        Lifecycle_Compartment_unref(self->__compartment);
        self->__compartment = next_compartment;
        if (next_compartment->forward_event == NULL) {
            // No forwarded event — synthesize a fresh $>
            Lifecycle_FrameEvent* __enter_event = Lifecycle_FrameEvent_new("$>", self->__compartment->enter_args, 0);
            Lifecycle_router(self, __enter_event);
            Lifecycle_FrameEvent_destroy(__enter_event);
        } else if (strcmp(next_compartment->forward_event->_message, "$>") == 0) {
            // Forwarded event IS $> — dispatch directly so the
            // destination's $> handler receives the caller's payload.
            // The forward_event is borrowed (owned by the wrapper that
            // queued the transition) — do NOT destroy it here.
            Lifecycle_FrameEvent* forward_event = next_compartment->forward_event;
            next_compartment->forward_event = NULL;
            Lifecycle_router(self, forward_event);
        } else {
            // Forwarded event is not $> — initialize the destination
            // with a fresh $>, then dispatch the forward to it. The
            // forward_event is borrowed; only the synthesized $> belongs
            // to the kernel and is freed here.
            Lifecycle_FrameEvent* forward_event = next_compartment->forward_event;
            next_compartment->forward_event = NULL;
            Lifecycle_FrameEvent* __enter_event = Lifecycle_FrameEvent_new("$>", self->__compartment->enter_args, 0);
            Lifecycle_router(self, __enter_event);
            Lifecycle_FrameEvent_destroy(__enter_event);
            Lifecycle_router(self, forward_event);
        }
        // Mark every stacked context as having transitioned. Read by
        // @@:self.X() guard so outer self-calls short-circuit.
        for (int __i = 0; __i < self->_context_stack->size; __i++) {
            ((Lifecycle_FrameContext*)self->_context_stack->items[__i])->_transitioned = 1;
        }
    }
}

static void Lifecycle_router(Lifecycle* self, Lifecycle_FrameEvent* __e) {
    if (strcmp(self->__compartment->state, "Idle") == 0) {
        Lifecycle_state_Idle(self, __e, self->__compartment);
    } else if (strcmp(self->__compartment->state, "Running") == 0) {
        Lifecycle_state_Running(self, __e, self->__compartment);
    }
}

static void Lifecycle_transition(Lifecycle* self, Lifecycle_Compartment* next_compartment) {
    self->__next_compartment = next_compartment;
}

void Lifecycle_destroy(Lifecycle* self) {
    // Unref current compartment (may free if not on stack)
    if (self->__compartment) Lifecycle_Compartment_unref(self->__compartment);
    if (self->__next_compartment) Lifecycle_Compartment_unref(self->__next_compartment);
    // Unref all state stack entries
    if (self->_state_stack) {
        for (int __i = 0; __i < self->_state_stack->size; __i++) {
            Lifecycle_Compartment_unref((Lifecycle_Compartment*)self->_state_stack->items[__i]);
        }
        Lifecycle_FrameVec_destroy(self->_state_stack);
    }
    if (self->_context_stack) Lifecycle_FrameVec_destroy(self->_context_stack);
    free(self);
}

void Lifecycle_start(Lifecycle* self, char* label) {
    Lifecycle_FrameVec* __params = Lifecycle_FrameVec_new();
    Lifecycle_FrameVec_push(__params, (void*)(intptr_t)label);
    Lifecycle_FrameEvent* __e = Lifecycle_FrameEvent_new("start", __params, 1);
    Lifecycle_FrameContext* __ctx = Lifecycle_FrameContext_new(__e, NULL);
    Lifecycle_FrameVec_push(self->_context_stack, __ctx);
    Lifecycle_kernel(self, __e);
    Lifecycle_FrameContext* __result_ctx = (Lifecycle_FrameContext*)Lifecycle_FrameVec_pop(self->_context_stack);
    Lifecycle_FrameContext_destroy(__result_ctx);
    Lifecycle_FrameEvent_destroy(__e);
}

void Lifecycle_stop(Lifecycle* self) {
    Lifecycle_FrameEvent* __e = Lifecycle_FrameEvent_new("stop", NULL, 0);
    Lifecycle_FrameContext* __ctx = Lifecycle_FrameContext_new(__e, NULL);
    Lifecycle_FrameVec_push(self->_context_stack, __ctx);
    Lifecycle_kernel(self, __e);
    Lifecycle_FrameContext* __result_ctx = (Lifecycle_FrameContext*)Lifecycle_FrameVec_pop(self->_context_stack);
    Lifecycle_FrameContext_destroy(__result_ctx);
    Lifecycle_FrameEvent_destroy(__e);
}

static void Lifecycle_state_Idle(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    if (strcmp(__e->_message, "start") == 0) {
        Lifecycle_s_Idle_hdl_user_start(self, __e, compartment);
        return;
    }
}

static void Lifecycle_state_Running(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    if (strcmp(__e->_message, "<$") == 0) {
        Lifecycle_s_Running_hdl_frame_exit(self, __e, compartment);
        return;
    }
    if (strcmp(__e->_message, "$>") == 0) {
        Lifecycle_s_Running_hdl_frame_enter(self, __e, compartment);
        return;
    }
    if (strcmp(__e->_message, "stop") == 0) {
        Lifecycle_s_Running_hdl_user_stop(self, __e, compartment);
        return;
    }
}

static void Lifecycle_s_Idle_hdl_user_start(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    const char* label = (const char*)Lifecycle_FrameVec_get(__e->_parameters, 0);
    (void)label;
    (label)
    {
        Lifecycle_FrameVec* __sa = NULL;
        Lifecycle_FrameVec* __ea = NULL;
        Lifecycle_Compartment* __compartment = Lifecycle_prepareEnter(self, "Running", __sa, __ea);
        Lifecycle_transition(self, __compartment);
    }
    return;
}

static void Lifecycle_s_Running_hdl_frame_exit(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    self.exited = self.exited + 1
}

static void Lifecycle_s_Running_hdl_frame_enter(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    const char* label = (const char*)Lifecycle_FrameVec_get(compartment->enter_args, 0);
    (void)label;
    self.entered = self.entered + 1
    self.tag = label
}

static void Lifecycle_s_Running_hdl_user_stop(Lifecycle* self, Lifecycle_FrameEvent* __e, Lifecycle_Compartment* compartment) {
    {
        Lifecycle_FrameVec* __sa = NULL;
        Lifecycle_FrameVec* __ea = NULL;
        Lifecycle_Compartment* __compartment = Lifecycle_prepareEnter(self, "Idle", __sa, __ea);
        Lifecycle_transition(self, __compartment);
    }
    return;
}
